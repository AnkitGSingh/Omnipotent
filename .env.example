# ──────────────────────────────────────────────────────────────────
# OmniChat / Omnipotent — Environment Variables
# Copy this file to .env.local (frontend) and backend/.env (backend)
# NEVER commit actual secrets to version control.
# ──────────────────────────────────────────────────────────────────

# ── Clerk (Auth) ──────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk sign-in / sign-up redirect paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string (pgvector extension required)
DATABASE_URL=postgresql://user:password@localhost:5432/omnichat

# ── AWS Bedrock ───────────────────────────────────────────────────
# IAM user with bedrock:InvokeModel permission
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
# Optional: Only needed for temporary/assumed-role credentials
# AWS_SESSION_TOKEN=

# ── Ollama (self-hosted) ──────────────────────────────────────────
# URL of your hosted Ollama instance (default: localhost for dev)
OLLAMA_BASE_URL=http://localhost:11434

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── Frontend API URL ──────────────────────────────────────────────
# URL of the FastAPI backend as seen from the browser
NEXT_PUBLIC_API_URL=http://localhost:8000
